  "keyFeatures": [
    "Automated installation scripts for complete Alfresco deployment",
    "Multiple version profiles (7.4 LTS, 23.x, 25.x)",
    "Automatic memory tuning based on system resources",
    "Multi-machine deployment support with distributed architecture",
    "Integrated backup and restore functionality",
    "Add-on management (AMP and JAR modules)",
    "Service lifecycle management with health checks",
    "HTTPS/TLS 1.3 configuration support",
    "PostgreSQL automatic tuning",
    "Complete component stack (PostgreSQL, Tomcat, ActiveMQ, Solr, Transform, Nginx)"
  ],
  "publicApiSurface": [
    "00-generate-config.sh - Generate secure configuration with random passwords",
    "01-install_postgres.sh - Install and configure PostgreSQL database",
    "02-install_java.sh - Install OpenJDK runtime",
    "03-install_tomcat.sh - Install Apache Tomcat application server",
    "04-install_activemq.sh - Install Apache ActiveMQ message broker",
    "05-download_alfresco_resources.sh - Download Alfresco distribution files",
    "06-install_alfresco.sh - Install Alfresco Repository and Share",
    "07-install_solr.sh - Install Alfresco Search Services (Solr)",
    "08-install_transform.sh - Install Transform Service with LibreOffice",
    "09-build_aca.sh - Build Alfresco Content App frontend",
    "10-install_nginx.sh - Install and configure Nginx reverse proxy",
    "11-start_services.sh - Start all services in correct order with health checks",
    "12-stop_services.sh - Stop all services gracefully in reverse order",
    "13-backup.sh - Create full or partial backups (database, content, config, solr)",
    "14-restore.sh - Restore from backup archives",
    "15-install_addons.sh - Install AMP and JAR add-ons",
    "common.sh - Shared functions and configuration loading"
  ]
